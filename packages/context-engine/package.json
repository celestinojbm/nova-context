{
  "name": "@nova/context-engine",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./secret-box": {
      "types": "./dist/secret-box.d.ts",
      "import": "./dist/secret-box.js"
    },
    "./visual-redaction": {
      "types": "./dist/visual-redaction.d.ts",
      "import": "./dist/visual-redaction.js"
    },
    "./object-store": {
      "types": "./dist/object-store.d.ts",
      "import": "./dist/object-store.js"
    },
    "./media-gate": {
      "types": "./dist/media-gate.d.ts",
      "import": "./dist/media-gate.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nova/schema": "workspace:*",
    "jimp": "^1.6.1",
    "@aws-sdk/client-s3": "^3.1084.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "pg": "^8.13.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "pg": "^8.13.0"
  }
}
