{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "NOVA_API_TOKEN",
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "NOVA_INTENT_MODEL",
    "NOVA_ENRICH_MODEL",
    "NOVA_CLOUD_ENRICHMENT",
    "NOVA_ENRICHMENT_QUEUE",
    "NOVA_REDACTION",
    "NOVA_LIVE_QA",
    "NOVA_LIVE_MODEL",
    "NOVA_ANALYTICS",
    "NOVA_API_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", ".output/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
