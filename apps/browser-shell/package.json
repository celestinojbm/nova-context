{
  "name": "@nova/browser-shell",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "exports": {
    "./capture": {
      "types": "./dist/capture.d.ts",
      "default": "./dist/capture.js"
    },
    "./api-client": {
      "types": "./dist/api-client.d.ts",
      "default": "./dist/api-client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "electron ."
  },
  "dependencies": {
    "@nova/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^33.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
