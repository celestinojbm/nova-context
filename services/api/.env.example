# Postgres connection (pgvector image from infra/docker-compose.dev.yml)
DATABASE_URL=postgres://nova:nova@localhost:5432/nova
# Port the API listens on
PORT=3001
# Optional shared bearer token. If set, all /v1 requests must send
# "Authorization: Bearer <token>". Leave unset for open local dev.
# Real OAuth 2.1 + scopes arrive with the developer platform, not M0.
NOVA_API_TOKEN=

# --- Model providers (optional; the app degrades gracefully) ---------------
# Used for (1) voice transcription via OpenAI Whisper and (2) query-time
# embeddings for the vector search leg. PRIVACY: when set, recorded voice
# instructions are sent to OpenAI for transcription (audio held in memory
# only, never persisted; disclosed in the extension UI) and search query
# text is sent for embedding. Unset => transcription returns 503 (typed
# input still works) and memory search runs keyword-only.
# NOTE: LLM enrichment keys live in services/worker/.env — the API never
# calls an LLM on the capture path (M2).
OPENAI_API_KEY=

# --- M2 enrichment queue ----------------------------------------------------
# Redis for BullMQ (infra/docker-compose.dev.yml provides it). When set, each
# capture enqueues an enrichment job for services/worker and returns
# immediately. When unset, moments are stored with enrichment_status
# 'skipped' and everything else keeps working.
REDIS_URL=redis://localhost:6379

# --- M3 live Q&A + redaction ------------------------------------------------
# Live Q&A grounding model (Anthropic, vision). PRIVACY: when enabled, live
# questions plus a minimized, ALREADY-REDACTED slice of the live buffer
# (recent frames, visible text, session Q&A) are sent to Anthropic to answer.
# This is the only API path that sends captured content to a cloud model.
# NOVA_LIVE_QA=off disables it even with a key (endpoint returns 503).
ANTHROPIC_API_KEY=
NOVA_LIVE_QA=auto
# Optional model override for live Q&A (default: claude-opus-4-8).
NOVA_LIVE_MODEL=

# Capture-time redaction of obvious sensitive data (emails, phones, cards,
# API keys/tokens, SSNs, IBANs) before anything is stored, enriched, or
# audited. 'off' stores captures verbatim (redaction_state 'skipped').
NOVA_REDACTION=on
