# Postgres connection (pgvector image from infra/docker-compose.dev.yml)
DATABASE_URL=postgres://nova:nova@localhost:5432/nova
# Port the API listens on
PORT=3001

# --- M5 authentication -------------------------------------------------------
# Sessions are opaque server-side tokens (web: HttpOnly cookie held by the
# Next.js app; extension: device token from the pairing flow). All /v1
# routes require them — there is no anonymous or shared-token mode.
# See docs/AUTH.md.
#
# Signup policy: 'open' (default in dev) | 'invite' | 'closed'.
# In production (NODE_ENV=production) the default is 'invite': without
# NOVA_ALPHA_INVITE_CODE set, no signup can succeed (fails closed).
NOVA_SIGNUP=
# Required when NOVA_SIGNUP=invite (min 8 chars). Share with alpha testers.
NOVA_ALPHA_INVITE_CODE=
# Session lifetimes in hours (fixed expiry). Defaults: 168 (7d web),
# 720 (30d extension).
NOVA_SESSION_TTL_HOURS=
NOVA_EXTENSION_SESSION_TTL_HOURS=

# --- M6 integrations (Notion) ------------------------------------------------
# AES-256-GCM key for integration tokens at rest (32 bytes, hex or base64;
# generate with `openssl rand -hex 32`). REQUIRED for any integration:
# without it, connect/execute fails closed. In production, setting
# NOTION_CLIENT_ID without this key refuses to boot. Must match the
# worker's NOVA_ENCRYPTION_KEY.
NOVA_ENCRYPTION_KEY=
# Notion OAuth app (https://www.notion.so/my-integrations, public
# integration). The redirect URI is the WEB APP callback, e.g.
# http://localhost:3000/integrations/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=
# Queue name for approved external actions (mainly for test isolation).
NOVA_ACTION_QUEUE=action-execution

# --- M7 visual redaction -------------------------------------------------------
# OCR-box masking of screenshots/live frames BEFORE storage, live Q&A,
# export, or adapter use. On-process Tesseract — pixels never leave the API.
NOVA_IMAGE_REDACTION=on
# Server-side kill switch: 'off' strips every image payload before storage.
NOVA_SCREENSHOT_STORAGE=on
# Tesseract language data location (vendor a local copy for air-gapped
# deploys); unset = tesseract.js default CDN, fetched once and cached.
NOVA_OCR_LANG_PATH=
# Per-image OCR time budget (ms). Timeouts count as redaction failures and
# trigger the fail-safe (strict mode drops the image; live Q&A drops frames).
NOVA_OCR_TIMEOUT_MS=10000

# --- M8 media pipeline --------------------------------------------------------
# Screenshots/frames no longer live in the moment payload: after redaction
# they are AES-256-GCM encrypted (NOVA_ENCRYPTION_KEY above — REQUIRED in
# production; without it the media pipeline fails closed and images are
# dropped, never stored) and written to object storage, referenced from
# moment_media, and served only through the authenticated proxy
# GET /v1/media/:id. Backend: 'fs' (default, local directory) or 's3'
# (any S3-compatible endpoint — AWS, MinIO, R2).
NOVA_MEDIA_STORE=fs
# fs backend: blob root (relative to the API working dir unless absolute).
NOVA_MEDIA_FS_ROOT=./var/media
# s3 backend (all required except REGION/ENDPOINT). For local MinIO
# (`docker compose --profile media-s3 up -d minio` in infra/):
#   NOVA_MEDIA_S3_ENDPOINT=http://localhost:9000, bucket created via :9001.
NOVA_MEDIA_S3_BUCKET=
NOVA_MEDIA_S3_REGION=us-east-1
NOVA_MEDIA_S3_ENDPOINT=
NOVA_MEDIA_S3_ACCESS_KEY_ID=
NOVA_MEDIA_S3_SECRET_ACCESS_KEY=
# Legacy inline media (pre-M8 rows) is moved by the manual operator command
# `pnpm --filter @nova/api media:backfill` — see docs/AUTH.md.

# --- M9 media operations --------------------------------------------------------
# Audit direct media views (media.view rows: id + variant only). Off by
# default — a timeline render would write a row per thumbnail. Exports,
# deletes, and adapter access are ALWAYS audited regardless.
NOVA_MEDIA_VIEW_AUDIT=off
# Previous encryption key — set ONLY while running the key-rotation command:
#   NOVA_ENCRYPTION_KEY=<new> NOVA_ENCRYPTION_KEY_OLD=<current> \
#     pnpm --filter @nova/api media:rotate-key -- --apply
# The API itself never reads it. Other M9 operator commands:
#   pnpm --filter @nova/api media:cleanup              # orphan scan (dry run)
#   pnpm --filter @nova/api media:cleanup -- --delete  # remove orphans + retry failed deletes
NOVA_ENCRYPTION_KEY_OLD=

# --- M7 auth hardening ----------------------------------------------------------
# Credential-surface rate limit: attempts per 15-minute window per IP.
# Shared across instances through Redis when REDIS_URL is set.
NOVA_RATE_LIMIT_MAX=30
NOVA_RATE_LIMIT_PREFIX=nova:ratelimit

# --- Model providers (optional; the app degrades gracefully) ---------------
# Used for (1) voice transcription via OpenAI Whisper and (2) query-time
# embeddings for the vector search leg. PRIVACY: when set, recorded voice
# instructions are sent to OpenAI for transcription (audio held in memory
# only, never persisted; disclosed in the extension UI) and search query
# text is sent for embedding. Unset => transcription returns 503 (typed
# input still works) and memory search runs keyword-only.
# NOTE: LLM enrichment keys live in services/worker/.env — the API never
# calls an LLM on the capture path (M2).
OPENAI_API_KEY=

# --- M2 enrichment queue ----------------------------------------------------
# Redis for BullMQ (infra/docker-compose.dev.yml provides it). When set, each
# capture enqueues an enrichment job for services/worker and returns
# immediately. When unset, moments are stored with enrichment_status
# 'skipped' and everything else keeps working.
REDIS_URL=redis://localhost:6379

# --- M3 live Q&A + redaction ------------------------------------------------
# Live Q&A grounding model (Anthropic, vision). PRIVACY: when enabled, live
# questions plus a minimized, ALREADY-REDACTED slice of the live buffer
# (recent frames, visible text, session Q&A) are sent to Anthropic to answer.
# This is the only API path that sends captured content to a cloud model.
# NOVA_LIVE_QA=off disables it even with a key (endpoint returns 503).
ANTHROPIC_API_KEY=
NOVA_LIVE_QA=auto
# Optional model override for live Q&A (default: claude-opus-4-8).
NOVA_LIVE_MODEL=

# Capture-time redaction of obvious sensitive data (emails, phones, cards,
# API keys/tokens, SSNs, IBANs) before anything is stored, enriched, or
# audited. 'off' stores captures verbatim (redaction_state 'skipped').
NOVA_REDACTION=on

# --- M4 analytics -------------------------------------------------------------
# Funnel instrumentation. 'local' (default) stores allowlisted product events
# (event name + numeric/boolean props, never captured content) in Postgres.
# 'off' disables analytics entirely.
NOVA_ANALYTICS=local

# --- M11 alpha operations -------------------------------------------------------
# Previous encryption keys (comma-separated) the API may still READ media
# and tokens with during a gradual key rotation. Writes always use
# NOVA_ENCRYPTION_KEY. Set during rotation, remove after `media:verify`
# passes with only the new key. See infra/DEPLOY.md §Key rotation.
NOVA_ENCRYPTION_KEYS_PREVIOUS=
# Build/commit identifier shown on the internal /status page.
NOVA_GIT_SHA=
# Operator commands added in M11:
#   pnpm --filter @nova/api ops:maintenance [-- --apply] [-- --prune-events-days=N]
#   pnpm --filter @nova/api media:verify          # backup/restore verification
#   pnpm --filter @nova/api auth:reset-token -- <email>   # password reset link

# --- M13 private alpha operations ------------------------------------------------
# Fail-closed acknowledgement: production refuses to boot with
# NOVA_REDACTION=off or NOVA_IMAGE_REDACTION=off unless this is 'yes'.
NOVA_ALLOW_UNSAFE_REDACTION=
# Hard request-duration cap (ms) and the media-storage total (MB) above
# which /status and ops:report raise a warning.
NOVA_REQUEST_TIMEOUT_MS=60000
NOVA_MEDIA_WARN_MB=1024
# M13 operator commands:
#   pnpm --filter @nova/api ops:preflight     # pre-deploy checks (PREFLIGHT OK)
#   pnpm --filter @nova/api ops:smoke -- --base-url=<api> [--invite=<code>]
#   pnpm --filter @nova/api ops:report [-- --days=30]   # alpha usage/friction
# Smoke can also read NOVA_SMOKE_BASE_URL / NOVA_SMOKE_INVITE.

# --- M15 alpha blocker remediation (Hermes audit) -------------------------------
# Authenticated-encryption key for BACKUP artifacts. SEPARATE from
# NOVA_ENCRYPTION_KEY (data at rest) and NEVER written into a backup. Required
# by scripts/backup.sh and scripts/restore.sh (backups are always sealed;
# there is no plaintext-backup path). Generate with `openssl rand -hex 32`.
NOVA_BACKUP_KEY=
# Restore guardrails (scripts/restore.sh):
#   NOVA_RESTORE_CONFIRM=RESTORE           # skip the interactive typed confirm
#   NOVA_RESTORE_ALLOW_PRODUCTION=yes      # REQUIRED to restore into production
# Backup operator commands:
#   pnpm --filter @nova/api backup:verify -- --dir=<dir> --stamp=<stamp>
