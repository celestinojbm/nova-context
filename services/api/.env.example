# Postgres connection (pgvector image from infra/docker-compose.dev.yml)
DATABASE_URL=postgres://nova:nova@localhost:5432/nova
# Port the API listens on
PORT=3001
# Optional shared bearer token. If set, all /v1 requests must send
# "Authorization: Bearer <token>". Leave unset for open local dev.
# Real OAuth 2.1 + scopes arrive with the developer platform, not M0.
NOVA_API_TOKEN=

# --- M1 model providers (both optional; the app degrades gracefully) -------
# Voice transcription (OpenAI Whisper). PRIVACY: when set, recorded voice
# instructions are sent to OpenAI for transcription. Nova holds audio in
# memory only — it is never written to disk or the database — and the cloud
# ASR use is disclosed in the extension UI. Unset => POST /v1/transcriptions
# returns 503 and the extension falls back to typed input.
OPENAI_API_KEY=

# Intent parsing (Anthropic). PRIVACY: when set, the user's instruction text
# and the captured page title are sent to Anthropic to produce the structured
# intent. Unset => the local deterministic heuristic parser is used instead.
ANTHROPIC_API_KEY=
# Optional model override for intent parsing (default: claude-opus-4-8).
NOVA_INTENT_MODEL=
