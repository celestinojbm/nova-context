{
  "name": "@nova/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed-dev": "tsx src/db/seed-dev.ts",
    "auth:reset-password": "tsx src/db/reset-password.ts",
    "media:backfill": "tsx src/db/backfill-media.ts",
    "media:cleanup": "tsx src/db/cleanup-media.ts",
    "media:rotate-key": "tsx src/db/rotate-media-key.ts",
    "test": "vitest run --dir src",
    "test:integration": "vitest run --dir test",
    "ops:maintenance": "tsx src/db/run-maintenance.ts",
    "media:verify": "tsx src/db/verify-media.ts",
    "auth:reset-token": "tsx src/db/reset-token.ts",
    "ops:preflight": "tsx src/db/run-preflight.ts",
    "ops:smoke": "tsx src/db/run-smoke.ts",
    "ops:report": "tsx src/db/run-report.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1084.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@nova/context-engine": "workspace:*",
    "@nova/model-router": "workspace:*",
    "@nova/schema": "workspace:*",
    "bullmq": "^5.34.0",
    "fastify": "^5.1.0",
    "ioredis": "^5.11.1",
    "jimp": "^1.6.1",
    "pg": "^8.13.0",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nova/browser-shell": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
