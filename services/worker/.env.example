# Postgres — same database as services/api.
DATABASE_URL=postgres://nova:nova@localhost:5432/nova
# Redis — same instance the API enqueues to.
REDIS_URL=redis://localhost:6379

# --- Cloud enrichment (all optional; local heuristics otherwise) ------------
# PRIVACY: when cloud enrichment is active, the worker sends the captured
# page text (truncated to ~6k chars), page title, URL, and the user's
# instruction to Anthropic to produce summary/entities/tags/candidates.
# This is the ONLY place captured screen content leaves the machine, and it
# is controlled here, explicitly.
ANTHROPIC_API_KEY=
# Explicit switch for sending captured content to the LLM:
#   auto (default) = cloud enrichment iff ANTHROPIC_API_KEY is set
#   off            = never send captured content, even with a key configured
NOVA_CLOUD_ENRICHMENT=auto
# Optional model override for enrichment (default: claude-opus-4-8).
NOVA_ENRICH_MODEL=

# Embeddings (OpenAI text-embedding-3-small, 1536-dim). When set, the worker
# writes a vector per enriched moment, enabling the vector search leg.
OPENAI_API_KEY=

# Funnel analytics ('local' stores allowlisted events in Postgres, 'off' drops).
NOVA_ANALYTICS=local

# --- M6 external action execution ---------------------------------------------
# Same key as the API's NOVA_ENCRYPTION_KEY — decrypts per-user integration
# tokens. Without it, external actions fail closed ('encryption_key_missing').
NOVA_ENCRYPTION_KEY=
# Queue carrying approved external actions from the API.
NOVA_ACTION_QUEUE=action-execution
