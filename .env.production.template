# ============================================================================
# Nova Context — PRODUCTION environment TEMPLATE (M17A operator packet)
# ============================================================================
# PLACEHOLDERS ONLY. This file is committed; a filled-in copy is NOT.
#   - Copy per service, fill in, and store it ONLY in your provider's secret
#     manager (e.g. `fly secrets set ...`) — never on disk in the repo.
#   - `.env.production` and `.env.*.local` are gitignored: NEVER commit real
#     values. NEVER paste real secrets into any doc, PR, issue, or log.
#   - `<generate:...>` = run the command and paste the OUTPUT (a fresh secret).
#   - `<operator:...>` = a value only you/your provider can supply.
# The authoritative per-variable docs are services/{api,worker}/.env.example
# and docs/M17_OPERATOR_INFRASTRUCTURE_PACKET.md. Safe posture is baked in
# below: strict redaction ON, signup invite-only, all cloud/integration
# features OFF at first deploy.
# ============================================================================

# --- app / runtime ----------------------------------------------------------
NODE_ENV=production
# API listen port (provider may inject its own; Fly uses the toml internal_port)
PORT=3001
# Build/commit id shown on the internal /status page (set from CI, e.g. git sha)
NOVA_GIT_SHA=<operator:git-sha>

# --- database (managed Postgres 16 WITH pgvector) ---------------------------
# CREATE EXTENSION vector must be permitted; the migration runs it.
DATABASE_URL=<operator:postgres-connection-string>

# --- redis (BullMQ; plain connection string) --------------------------------
REDIS_URL=<operator:redis-connection-string>

# --- media object storage (PREFER s3-compatible in production) --------------
# fs requires a persistent volume; s3 (AWS/MinIO/R2) is recommended.
NOVA_MEDIA_STORE=s3
NOVA_MEDIA_S3_BUCKET=<operator:private-bucket-name>
NOVA_MEDIA_S3_REGION=<operator:region>
# Leave ENDPOINT empty for AWS; set for MinIO/R2/other S3-compatible hosts.
NOVA_MEDIA_S3_ENDPOINT=
NOVA_MEDIA_S3_ACCESS_KEY_ID=<operator:s3-access-key-id>
NOVA_MEDIA_S3_SECRET_ACCESS_KEY=<operator:s3-secret-access-key>
# fs fallback (only if NOVA_MEDIA_STORE=fs — needs a persistent, private volume):
NOVA_MEDIA_FS_ROOT=

# --- encryption (data at rest: media blobs + integration tokens) ------------
# REQUIRED in production. 32 bytes hex. Must MATCH between API and worker.
# Losing this key makes media/tokens unrecoverable (restore = metadata only).
NOVA_ENCRYPTION_KEY=<generate: openssl rand -hex 32>
# Set ONLY during a key rotation (comma-separated previous keys, read-only):
NOVA_ENCRYPTION_KEYS_PREVIOUS=

# --- backup (SEPARATE authenticated-encryption key for sealed backups) ------
# REQUIRED by scripts/backup.sh + scripts/restore.sh. MUST be different from
# NOVA_ENCRYPTION_KEY and is NEVER written into a backup. Losing it makes
# backups unrecoverable. Store in the secret manager, apart from the backups.
NOVA_BACKUP_KEY=<generate: openssl rand -hex 32>

# --- media backup destination (M18A; s3 media store only) --------------------
# A SEPARATE bucket (never the media bucket) for media:backup-s3 — encrypted
# blobs are copied AS STORED with an HMAC-authenticated inventory. Prefer a
# separately-scoped credential (e.g. an R2 token limited to this bucket).
# Region/endpoint/credentials fall back to the NOVA_MEDIA_S3_* values.
NOVA_BACKUP_S3_BUCKET=<operator:private-backup-bucket-name>
NOVA_BACKUP_S3_REGION=
NOVA_BACKUP_S3_ENDPOINT=
NOVA_BACKUP_S3_ACCESS_KEY_ID=<operator:scoped-backup-access-key-id>
NOVA_BACKUP_S3_SECRET_ACCESS_KEY=<operator:scoped-backup-secret-access-key>

# --- sealed-backup off-box persistence (M18A.2 §3; backup JOB only) ----------
# When "yes", scripts/backup.sh also PUBLISHES the complete sealed set (encrypted
# DB dump + media tar + manifest + media inventory) to sealed-backups/<stamp>/ in
# NOVA_BACKUP_S3_BUCKET, bound by an HMAC-authenticated commit marker written
# LAST, then re-verifies it — so an ephemeral Render one-off job's backup
# survives teardown. No plaintext is uploaded. Leave empty (off) for the API/
# worker services; set only on the backup job.
NOVA_BACKUP_PUBLISH_S3=
# (M18A.3 §4) Fail-closed off-box durability. When "yes", scripts/backup.sh
# REFUSES to finish unless the sealed set was published + verified off-box
# (i.e. NOVA_BACKUP_PUBLISH_S3=yes). Set on any backup job whose host disk is
# ephemeral, so a local-only seal is never mistaken for a durable backup.
NOVA_BACKUP_REQUIRE_OFFBOX=

# --- authorized remote scratch recovery (M18A.2 §1; recovery JOB only) --------
# The recovery gate's scratch guard normally accepts only loopback Postgres. To
# drill against a TEMPORARY managed (remote) scratch Postgres, ALL of the
# following must be set on the recovery job (names only — never the primary DSN;
# the fingerprints are credential-free sha256 of the target identity, printed by
# `pnpm --filter @nova/api backup:scratch-guard -- --fingerprint`). Any mismatch
# BLOCKS before mutation. NEVER set these on the primary API/worker services.
NOVA_VALIDATE_ALLOW_REMOTE_SCRATCH=
NOVA_RESTORE_TARGET_CLASS=
NOVA_RESTORE_SCRATCH_CONFIRM=
NOVA_RESTORE_EXPECT_HOST=
NOVA_RESTORE_EXPECT_DATABASE=
NOVA_RESTORE_EXPECT_FINGERPRINT=
NOVA_PRIMARY_DATABASE_FINGERPRINT=
NOVA_RECOVERY_RUN_ID=
# (M18A.3 §1) scripts/restore.sh authorization mode. "authorized-scratch" makes
# the script use the EXACT backup:scratch-guard decision the recovery gate
# validated (local loopback OR the full remote-scratch envelope above) and makes
# the manual production override INACCESSIBLE — this is what the automated drill
# / `validate:recovery-remote` uses. Leave empty for "manual" (default): the
# hands-on disaster-recovery path where a remote target needs the explicit
# NOVA_RESTORE_ALLOW_PRODUCTION=yes override. NEVER set the override on a drill.
NOVA_RESTORE_MODE=

# --- validation evidence retention (M18A; optional but recommended) ----------
# Gate reports (sanitized JSON/MD/JUnit + hashes) are uploaded to
# validation-evidence/<mode>/<run-id>/ in this PRIVATE bucket, because Render
# pre-deploy/one-off filesystems are ephemeral. Typically the backup bucket.
# Set NOVA_VALIDATE_EVIDENCE_REQUIRED=yes to make an upload failure fail the
# gate's exit code (retention is never silently claimed either way).
NOVA_VALIDATE_EVIDENCE_S3_BUCKET=<operator:private-backup-bucket-name>
NOVA_VALIDATE_EVIDENCE_S3_REGION=
NOVA_VALIDATE_EVIDENCE_S3_ENDPOINT=
NOVA_VALIDATE_EVIDENCE_S3_ACCESS_KEY_ID=<operator:scoped-backup-access-key-id>
NOVA_VALIDATE_EVIDENCE_S3_SECRET_ACCESS_KEY=<operator:scoped-backup-secret-access-key>
NOVA_VALIDATE_EVIDENCE_REQUIRED=

# --- auth / sessions --------------------------------------------------------
# Fixed session lifetimes (hours). Defaults 168 (7d web) / 720 (30d extension).
NOVA_SESSION_TTL_HOURS=168
NOVA_EXTENSION_SESSION_TTL_HOURS=720

# --- signup / invite (INVITE-ONLY in production; fails closed) --------------
NOVA_SIGNUP=invite
# min 8 chars. Without this, invite signups cannot succeed.
NOVA_ALPHA_INVITE_CODE=<generate: openssl rand -hex 12>

# --- redaction / media safety (KEEP ON — do not weaken) ---------------------
NOVA_REDACTION=on
NOVA_IMAGE_REDACTION=on
NOVA_SCREENSHOT_STORAGE=on
# Tesseract OCR budget (ms); timeouts are treated as redaction failures.
NOVA_OCR_TIMEOUT_MS=10000
# Optional local Tesseract lang data (recommended for prod: vendor a copy).
NOVA_OCR_LANG_PATH=
# MUST stay empty/unset. Production REFUSES to boot with redaction off unless
# this is 'yes' — leave it blank. Do NOT set to 'yes'.
NOVA_ALLOW_UNSAFE_REDACTION=

# --- feature gates: cloud + integrations OFF at first deploy -----------------
# Notion (leave BLANK to keep the integration OFF):
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=
# Cloud enrichment: 'off' = never send captured content to an LLM.
NOVA_CLOUD_ENRICHMENT=off
# Live Q&A: 'off' disables even if a key is present.
NOVA_LIVE_QA=off
# Model provider keys: leave BLANK to keep transcription / live QA /
# embeddings / enrichment OFF. (Anthropic = live QA + enrichment; OpenAI =
# transcription + embeddings.)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional model overrides (ignored while the above are OFF):
NOVA_LIVE_MODEL=
NOVA_ENRICH_MODEL=

# --- rate limiting ----------------------------------------------------------
# Credential-surface attempts per 15-min window per IP (Redis-shared).
NOVA_RATE_LIMIT_MAX=30
NOVA_RATE_LIMIT_PREFIX=nova:ratelimit

# --- logging / analytics ----------------------------------------------------
# 'local' = allowlisted product events (counts/flags only, never content) in
# Postgres. 'off' disables analytics. Never sends captured content anywhere.
NOVA_ANALYTICS=local

# --- ops thresholds ---------------------------------------------------------
NOVA_REQUEST_TIMEOUT_MS=60000
NOVA_MEDIA_WARN_MB=1024

# --- web app ----------------------------------------------------------------
# Server-side API base URL for the Next.js app (browser never calls the API directly).
NOVA_API_URL=<operator:https://api.your-domain>

# --- worker: also needs (same values as API) --------------------------------
#   DATABASE_URL, REDIS_URL, NOVA_ENCRYPTION_KEY, NOVA_MEDIA_* (ABSOLUTE fs
#   root if fs), NOVA_CLOUD_ENRICHMENT=off, NOVA_ANALYTICS, NOVA_ACTION_QUEUE.
NOVA_ACTION_QUEUE=action-execution

# --- restore-only guardrails (set transiently, only when restoring) ---------
#   NOVA_RESTORE_CONFIRM=RESTORE            # skip interactive typed confirm
#   NOVA_RESTORE_ALLOW_PRODUCTION=yes       # REQUIRED to restore a non-local target
# Do NOT keep these set in the running service environment.
